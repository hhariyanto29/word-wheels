/target
Cargo.lock

# ─── Android keystores & signing ─────────────────────────────────────
# NEVER commit these — losing a release keystore means losing the
# ability to ship updates under the same app listing.
*.jks
*.keystore
!**/debug.keystore   # allow checked-in debug keys (none right now)

# Gradle convention for keystore credentials
keystore.properties
signing.properties
key.properties

# ─── Android build output ────────────────────────────────────────────
android-native/.gradle/
android-native/build/
android-native/app/build/
android-native/local.properties
android-native/captures/
android-native/.idea/
android-native/*.iml
android-native/app/*.iml

# ─── iOS / Xcode ─────────────────────────────────────────────────────
# Generated by XcodeGen from project.yml — don't track it.
ios-native/WordWheel.xcodeproj/
ios-native/build/
ios-native/DerivedData/
ios-native/*.xcworkspace
xcuserdata/
*.xcuserstate

# Apple code-signing secrets
*.p12
*.mobileprovision
*.cer
*.certSigningRequest
AuthKey_*.p8

# ─── macOS ───────────────────────────────────────────────────────────
.DS_Store

# ─── Local-only drop zone for raw background art ─────────────────────
# Used as a staging folder before art is processed (compressed, renamed)
# into assets/backgrounds/. Keep raw originals out of git — they are
# typically multi-MB and superseded by the bundled compressed versions.
/incoming/
